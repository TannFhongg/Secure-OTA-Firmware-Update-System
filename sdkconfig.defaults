# OTA Configuration

# Partition Table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partition_table/partitions.csv"

# Flash size must fit both OTA slots.
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"

CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# WiFi defaults. Put real credentials in local sdkconfig via idf.py menuconfig.
CONFIG_EXAMPLE_WIFI_SSID="YOUR_WIFI_SSID"
CONFIG_EXAMPLE_WIFI_PASSWORD="YOUR_WIFI_PASSWORD"

# OTA URL must be HTTPS. Configure the real URL locally with idf.py menuconfig.
CONFIG_EXAMPLE_FIRMWARE_UPGRADE_URL="https://example.com/esp32-secure-ota.bin"
# CONFIG_EXAMPLE_AUTO_OTA_ON_BOOT is not set

# HTTPS and certificate validation
# CONFIG_ESP_HTTPS_OTA_ALLOW_HTTP is not set
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_CMN=y
CONFIG_EXAMPLE_USE_CERT_BUNDLE=y

# Production signed-app verification requires a signing key configured locally.
# Enable these in sdkconfig/menuconfig when the signing key is available:
# CONFIG_SECURE_SIGNED_APPS_NO_SECURE_BOOT=y
# CONFIG_SECURE_SIGNED_APPS_ECDSA_SCHEME=y

# Logging
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_DEFAULT_LEVEL=3

